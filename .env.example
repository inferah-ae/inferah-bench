# Copy to .env and fill in. .env is gitignored.

# Postgres the bench reads from. Default = the bundled docker-compose service.
PG_URL=postgresql+psycopg2://inferah:inferah@localhost:5544/inferah

# Model API keys. ANTHROPIC is needed for the default grid (arms A/B/D2 on
# claude-sonnet-4-6). OPENAI is needed only if you add OpenAI models below.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GEMINI_API_KEY=

# Which arms/models to run (comma-separated). Engine arms D2/D3 always run.
# BENCH_ARMS=A,B
# BENCH_MODELS=claude-sonnet-4-6,gpt-5.5
